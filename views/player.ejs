<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <title><%= channel.title %> - Live Player</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@1.4.10/dist/hls.min.js"></script>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #0b0c10; color: white; }
    .glass-card { background: rgba(22, 24, 32, 0.8); backdrop-filter: blur(10px); }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    #chat-box { height: 280px; overflow-y: auto; scroll-behavior: smooth; }
    #chat-history { height: 260px; overflow-y: auto; scroll-behavior: smooth; }
    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body class="min-h-screen flex flex-col items-center pb-10">

  <!-- 🎨 Top Bar -->
  <header class="w-full max-w-md px-5 py-6 flex items-center gap-4">
    <a href="/" class="p-2 -ml-2 text-gray-400 hover:text-white">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
    </a>
    <h1 class="text-sm font-bold tracking-tight truncate text-blue-500 uppercase"><%= channel.title %></h1>
  </header>

  <main class="w-full max-w-md px-4">
    <!-- 📺 Smart Player -->
    <div class="relative w-full aspect-video rounded-2xl overflow-hidden bg-black border border-white/5 shadow-2xl">
      <div id="loader" class="absolute inset-0 z-50 flex flex-col items-center justify-center bg-[#0b0c10]">
        <div class="w-10 h-10 border-4 border-blue-500/20 border-t-blue-500 rounded-full animate-spin"></div>
        <span class="mt-4 text-[10px] font-bold uppercase tracking-widest text-blue-500/60">Buffering</span>
      </div>

      <video id="video-player" class="w-full h-full object-contain hidden" controls playsinline></video>
      <iframe id="iframe-player" class="w-full h-full hidden" sandbox="allow-scripts allow-same-origin allow-presentation" allowfullscreen frameborder="0"></iframe>

      <!-- Custom Fullscreen Button -->
      <button id="fullscreen-btn" class="absolute bottom-4 right-4 z-40 bg-black/50 p-2 rounded-lg text-white hover:bg-black/70 transition-all hidden" aria-label="Toggle fullscreen">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-maximize">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3m-18 0v3a2 2 0 0 0 2 2h3"></path>
        </svg>
      </button>
    </div>

    <!-- 📊 Metadata & Action Buttons -->
    <div class="mt-6 flex flex-col gap-4">
      <div>
        <h2 class="text-xl font-bold"><%= channel.title %></h2>
        <p class="text-xs text-gray-500 font-medium"><%= channel.description %></p>
      </div>
      
      <button id="view-fullscreen-btn" class="w-full py-3 rounded-xl bg-white/5 border border-white/10 text-xs font-bold uppercase tracking-widest hover:bg-white/10 transition-all flex items-center justify-center gap-2">
        <span>📺 View Full Screen</span>
      </button>
    </div>

    <!-- 💬 Interactive Live Chat Component -->
    <section class="mt-8 glass-card rounded-2xl border border-white/5 overflow-hidden">
      <div class="px-4 py-3 border-b border-white/5 flex justify-between items-center">
        <span class="text-[10px] font-black tracking-widest text-gray-500 uppercase">Live Chat</span>
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
      </div>
      
      <div id="chat-history" class="p-4 flex flex-col no-scrollbar">
        <!-- Bubble messages appear here -->
      </div>

      <div class="p-3 bg-black/40 border-t border-white/5 flex gap-2 sticky bottom-0">
        <input id="chat-input" type="text" placeholder="Say something..." class="flex-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-blue-500/50 transition-all">
        <button onclick="sendMsg()" class="bg-blue-600 px-4 py-2 rounded-lg text-xs font-bold active:scale-95 transition-transform">Send</button>
      </div>
    </section>

    <!-- 🚀 Telegram Link -->
    <div class="mt-6 text-center">
      <a href="https://t.me/+I4XcTqHq-zBlZjZk" target="_blank" class="inline-block py-3 px-8 rounded-xl bg-blue-600 text-[11px] font-black uppercase tracking-widest shadow-lg shadow-blue-500/20 active:scale-95 transition-transform">
        Join our Telegram
      </a>
    </div>
  </main>

  <script>
    const telegram = window.Telegram.WebApp;
    telegram.ready();
    telegram.expand();

    const video = document.getElementById('video-player');
    const iframe = document.getElementById('iframe-player');
    const loader = document.getElementById('loader');
    const fullscreenBtn = document.getElementById('fullscreen-btn');
    const chatHistory = document.getElementById('chat-history');
    const chatInput = document.getElementById('chat-input');
    const viewFullscreenBtn = document.getElementById('view-fullscreen-btn');
    const channelId = "<%= channel.id %>";

    /**
     * 💬 Global Live Chat Sync
     */
    let lastMessageCount = 0;
    const userName = telegram.initDataUnsafe.user?.first_name || "You";

    async function fetchMessages() {
      try {
        const res = await fetch(`/api/chat/${channelId}`);
        const messages = await res.json();
        
        if (messages.length !== lastMessageCount) {
          chatHistory.innerHTML = "";
          messages.forEach(m => appendMessage(m.username, m.text, m.username === userName));
          lastMessageCount = messages.length;
          chatHistory.scrollTop = chatHistory.scrollHeight;
        }
      } catch (err) { console.error("Sync error:", err); }
    }

    async function sendMsg() {
      const text = chatInput.value.trim();
      if (!text) return;
      
      try {
        await fetch(`/api/chat/${channelId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: userName, text })
        });
        chatInput.value = "";
        fetchMessages();
      } catch (err) { alert("Message failed to send."); }
    }

    function appendMessage(name, text, isUser = false) {
      const msgDiv = document.createElement('div');
      msgDiv.className = `flex flex-col ${isUser ? 'items-end' : 'items-start'} animate-fade-in mb-3`;
      const bubbleClass = isUser ? 'bg-blue-600 text-white rounded-l-xl rounded-tr-xl' : 'bg-white/10 text-gray-200 rounded-r-xl rounded-tl-xl';
      
      msgDiv.innerHTML = `
        <span class="text-[9px] font-bold ${isUser ? 'text-blue-400' : 'text-gray-500'} mb-1 px-1">${name}</span>
        <div class="px-3 py-2 text-xs ${bubbleClass} max-w-[85%] break-words shadow-sm">
          ${text}
        </div>
      `;
      chatHistory.appendChild(msgDiv);
    }

    chatInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendMsg(); });
    
    let hls = null;
    const channelSrc = "<%= channel.src %>";

    /**
     * 🛡️ AGGRESSIVE AD & REDIRECT BLOCKING
     */
    window.open = function() { return null; };
    window.onbeforeunload = function() { return "External navigation blocked."; };

    window.addEventListener('blur', () => {
      if (document.activeElement === iframe) {
        setTimeout(() => window.focus(), 100);
      }
    });

    /**
     * 📺 Smart Player Logic
     */
    function initializePlayer() {
      const isHls = channelSrc.toLowerCase().includes('.m3u8') || channelSrc.includes('playlist');

      if (isHls) {
        iframe.classList.add('hidden');
        video.classList.remove('hidden');
        fullscreenBtn.classList.remove('hidden'); // Show fullscreen button for HLS
        
        if (Hls.isSupported()) {
          hls = new Hls({ capLevelToPlayerSize: true });
          hls.loadSource(channelSrc);
          hls.attachMedia(video);
          hls.on(Hls.Events.MANIFEST_PARSED, () => video.play().catch(() => {}));
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = channelSrc;
        }
      } else {
        video.classList.add('hidden');
        iframe.classList.remove('hidden');
        iframe.src = channelSrc;
        fullscreenBtn.classList.add('hidden'); // Hide fullscreen button for iframe
      }
    }

    // 🌀 Loading Spinner Logic
    video.addEventListener('playing', () => {
      loader.classList.add('hidden');
      fullscreenBtn.classList.remove('hidden');
    });
    video.addEventListener('waiting', () => {
      loader.classList.remove('hidden');
      fullscreenBtn.classList.add('hidden');
    });
    iframe.onload = () => {
      loader.classList.add('hidden');
      fullscreenBtn.classList.add('hidden'); // Hide for iframe
    };

    // Fullscreen button handlers
    function toggleFullscreen() {
      const activePlayer = video.style.display !== 'none' ? video : iframe;
      if (activePlayer.requestFullscreen) activePlayer.requestFullscreen();
      else if (activePlayer.webkitRequestFullscreen) activePlayer.webkitRequestFullscreen();
    }

    fullscreenBtn.addEventListener('click', toggleFullscreen);
    viewFullscreenBtn.addEventListener('click', toggleFullscreen);

    // Start Sync
    setInterval(fetchMessages, 2000);
    fetchMessages();
    initializePlayer();
  </script>
</body>
</html>