<!DOCTYPE html>
<html lang="en">
<head>
  <script src='//libtl.com/sdk.js' data-zone='11094774' data-sdk='show_11094774'></script>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <title><%= channel.title %> - 90 ደቂቃ Live</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; user-select: none; background-color: #0b0c10; }
    .glass-card { background: rgba(22, 24, 32, 0.8); backdrop-filter: blur(10px); }
    .player-aspect { aspect-ratio: 16 / 9; position: relative; width: 100%; }
    .pseudo-fullscreen {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100dvh !important;
        z-index: 10000 !important;
        background: #000 !important;
        border-radius: 0 !important;
        margin: 0 !important;
    }
    .control-gradient { background: linear-gradient(0deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 50%, rgba(0,0,0,0.8) 100%); }
    input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 12px; width: 12px; border-radius: 50%; background: #ffffff; cursor: pointer; border: 2px solid #3b82f6; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
  </style>
</head>
<body class="text-white min-h-screen flex flex-col items-center">
  
  <!-- Header -->
  <header class="w-full px-5 py-4 flex justify-between items-center z-50">
    <a href="/" class="p-2 -ml-2 text-gray-400">✕</a>
    <div class="flex flex-col items-center">
        <span class="text-[10px] font-black text-blue-500 uppercase tracking-widest">Live Match</span>
        <h1 class="text-xs font-bold truncate max-w-[150px]"><%= channel.title %></h1>
    </div>
    <div class="w-8"></div>
  </header>

  <main class="w-full max-w-4xl px-4 flex-1">
    <!-- 🎛️ Server Switcher -->
    <div class="flex items-center gap-3 mb-4 overflow-x-auto no-scrollbar py-2">
        <span class="text-[9px] font-bold text-gray-500 uppercase">Servers:</span>
        <% channel.servers.forEach((srv, index) => { %>
            <button onclick="switchServer(<%= index %>)" 
                    id="btn-srv-<%= index %>"
                    class="srv-btn w-8 h-8 rounded-full border border-white/10 text-[11px] font-black transition-all duration-300 flex items-center justify-center
                           <%= index === 0 ? 'border-blue-500 bg-blue-500/20 text-blue-500 shadow-[0_0_15px_rgba(59,130,246,0.4)]' : 'bg-white/5 text-gray-400' %>">
                <%= index + 1 %>
            </button>
        <% }) %>
    </div>

    <!-- 📺 Player Container -->
    <div id="player-wrapper" class="w-full bg-black rounded-3xl overflow-hidden shadow-2xl border border-white/5 flex flex-col">
        <div class="player-aspect">
            <div id="loading-spinner" class="absolute inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
                <div class="w-8 h-8 border-4 border-blue-500/20 border-t-blue-500 rounded-full animate-spin"></div>
            </div>
            <!-- Video Elements -->
            <video id="video-player" class="w-full h-full object-contain" playsinline></video>
            <iframe id="iframe-player" class="hidden w-full h-full border-none" 
                    sandbox="allow-scripts allow-same-origin allow-presentation allow-forms allow-autoplay allow-fullscreen" allowfullscreen></iframe>
        </div>
        <!--  Full Screen Controls (Text Based) -->
        <div id="fs-controls" class="py-4 flex justify-center gap-4 bg-[#0b0c10]">
            <button id="enter-fs-btn" onclick="toggleFullScreen()" class="px-6 py-2 rounded-xl bg-blue-600 text-[11px] font-bold uppercase tracking-widest active:scale-95 transition-all">View Full Screen</button>
            <button id="exit-fs-btn" onclick="toggleFullScreen()" class="hidden px-6 py-2 rounded-xl bg-red-600 text-[11px] font-bold uppercase tracking-widest active:scale-95 transition-all">Exit Full Screen</button>
        </div>
    </div>

    <!-- 🧧 Premium Station Promo Banner (Between FS Controls & Chat) -->
    <% if (promoConfig.showStationPromo) { %>
    <div class="mt-6 w-full">
        <a href="<%= promoConfig.stationPromo.link %>" target="_blank" class="block glass-card p-1 rounded-2xl border border-blue-500/40 bg-[#0b0c10] overflow-hidden relative group transition-all duration-500 hover:shadow-[0_0_25px_rgba(59,130,246,0.2)] active:scale-[0.98]">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-600/5 to-transparent pointer-events-none"></div>
            <div class="flex items-center gap-3 p-3 relative z-10">
                <div class="w-12 h-12 shrink-0 rounded-xl overflow-hidden border border-white/10 shadow-lg">
                    <img src="<%= promoConfig.stationPromo.imageUrl %>" class="w-full h-full object-cover" alt="Station Promo">
                </div>
                <div class="flex-1">
                    <span class="text-[8px] font-black text-blue-500 uppercase tracking-widest px-1.5 py-0.5 rounded bg-blue-500/10 border border-blue-500/20">Hot Offer</span>
                    <p class="text-xs font-bold text-white group-hover:text-blue-400 transition-colors line-clamp-1"><%= promoConfig.stationPromo.text %></p>
                </div>
                <div class="px-4 py-1.5 bg-blue-600 rounded-lg text-[10px] font-black uppercase shadow-lg shadow-blue-500/20">Join</div>
            </div>
        </a>
    </div>
    <% } %>

    <!--  Live Chat Module -->
    <section class="mt-8 mb-20">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-[11px] font-bold text-gray-500 uppercase tracking-widest">Match Chat</h3>
            <span class="flex items-center gap-1.5 text-[9px] text-green-500 font-bold uppercase">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span> Live
            </span>
        </div>
        <div id="chat-container" class="glass-card rounded-2xl border border-white/5 h-64 flex flex-col">
            <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3 no-scrollbar text-[13px]">
                <!-- Messages load here -->
            </div>
            <div class="p-3 border-t border-white/5 flex gap-2">
                <input id="chat-input" type="text" placeholder="Type a message..." class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-sm focus:outline-none focus:border-blue-500/50">
                <button onclick="sendMessage()" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-xl text-sm font-bold transition-colors">Send</button>
            </div>
        </div>
    </section>
  </main>

  <footer class="fixed bottom-6 left-0 right-0 px-6 z-50">
    <a href="https://t.me/+I4XcTqHq-zBlZjZk" target="_blank" class="glass-card flex items-center justify-between p-4 rounded-2xl border border-blue-500/20 shadow-[0_10px_30px_rgba(0,0,0,0.5)]">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-500 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.2-.08-.06-.19-.04-.27-.02-.12.02-1.96 1.25-5.54 3.69-.52.36-1 .53-1.42.52-.47-.01-1.37-.26-2.03-.48-.82-.27-1.47-.42-1.42-.88.03-.24.36-.48.99-.74 3.84-1.67 6.39-2.77 7.64-3.3 3.64-1.53 4.4-1.8 4.89-1.81.11 0 .35.03.5.15.13.11.17.26.18.37 0 .03.01.12 0 .2z"/></svg>
            </div>
            <div>
                <p class="text-[11px] font-bold">Join our Telegram</p>
                <p class="text-[9px] text-gray-500">Get instant match notifications</p>
            </div>
        </div>
        <span class="text-blue-500">→</span>
    </a>
  </footer>

  <script>
    const tg = window.Telegram.WebApp;
    tg.ready();
    tg.expand();

    // 💰 Monetag In-App Interstitial Ad Logic
    if (typeof show_11094774 === 'function') {
        show_11094774({
            type: 'inApp',
            inAppSettings: {
                frequency: 2,
                capping: 0.1,
                interval: 30,
                timeout: 5,
                everyPage: false 
            }
        });
    }

    const channelId = "<%= channel.id %>";
    const servers = <%- JSON.stringify(channel.servers) %>;
    const video = document.getElementById('video-player');
    const iframe = document.getElementById('iframe-player');
    const loader = document.getElementById('loading-spinner');
    let hls = null;

    // 🛡️ Security: Redirect prevention
    window.open = () => null;
    iframe.onload = () => loader.classList.add('hidden');

    function switchServer(index) {
        const srv = servers[index];
        
        // Update UI buttons
        document.querySelectorAll('.srv-btn').forEach((btn, i) => {
            btn.classList.remove('border-blue-500', 'bg-blue-500/20', 'text-blue-500', 'shadow-[0_0_15px_rgba(59,130,246,0.4)]');
            btn.classList.add('bg-white/5', 'text-gray-400');
            if(i === index) {
                btn.classList.add('border-blue-500', 'bg-blue-500/20', 'text-blue-500', 'shadow-[0_0_15px_rgba(59,130,246,0.4)]');
                btn.classList.remove('bg-white/5', 'text-gray-400');
            }
        });

        loader.classList.remove('hidden');
        
        if (srv.type === 'm3u8') {
            iframe.classList.add('hidden');
            video.classList.remove('hidden');
            iframe.src = "about:blank";
            loadHls(srv.url);
        } else {
            if (hls) { hls.destroy(); hls = null; }
            video.pause(); 
            video.src = "";
            video.load();
            video.classList.add('hidden');
            iframe.classList.remove('hidden');
            iframe.src = srv.url;
        }
    }

    function loadHls(url) {
        if (Hls.isSupported()) {
            if (hls) hls.destroy();
            hls = new Hls();
            hls.loadSource(url);
            hls.attachMedia(video);
            hls.on(Hls.Events.MANIFEST_PARSED, () => {
                loader.classList.add('hidden');
                video.play().catch(() => {
                    video.muted = true; // Fallback for autoplay restrictions
                    video.play();
                });
            });
            hls.on(Hls.Events.ERROR, (event, data) => {
                if (data.fatal) {
                    console.warn("HLS Fatal Error, attempting recovery...");
                    hls.recoverMediaError();
                }
            });
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
            video.src = url;
            video.addEventListener('loadedmetadata', () => {
                loader.classList.add('hidden');
                video.play();
            });
        }
    }

    let isPseudoFS = false;

    function syncFullScreenUI() {
        const isFS = !!(document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement || isPseudoFS);
        document.getElementById('enter-fs-btn').classList.toggle('hidden', isFS);
        document.getElementById('exit-fs-btn').classList.toggle('hidden', !isFS);
        
        const wrapper = document.getElementById('player-wrapper');
        const aspectBox = wrapper.querySelector('.player-aspect');
        if (isFS) {
            aspectBox.style.height = isPseudoFS ? "calc(100dvh - 60px)" : "100%";
            aspectBox.style.aspectRatio = "auto";
        } else {
            aspectBox.style.height = "";
            aspectBox.style.aspectRatio = "16 / 9";
        }
    }

    ['fullscreenchange', 'webkitfullscreenchange', 'mozfullscreenchange', 'MSFullscreenChange'].forEach(evt => 
        document.addEventListener(evt, syncFullScreenUI)
    );

    async function toggleFullScreen() {
        const container = document.getElementById('player-wrapper');
        const videoEl = document.getElementById('video-player');
        const isFS = document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement;

        if (!isFS && !isPseudoFS) {
            const requestFS = container.requestFullscreen || container.webkitRequestFullscreen || container.mozRequestFullScreen || container.msRequestFullscreen;
            if (requestFS) {
                try {
                    await requestFS.call(container);
                    // Try to lock orientation after entering true fullscreen
                    if (screen.orientation && screen.orientation.lock) {
                        await screen.orientation.lock('landscape').catch(e => console.log("Orientation lock failed:", e));
                    }
                } catch (err) {
                    enterPseudoFS();
                }
            } else if (videoEl.webkitEnterFullscreen) {
                videoEl.webkitEnterFullscreen();
            } else {
                enterPseudoFS();
            }
        } else {
            if (isFS) {
                const exitFS = document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen || document.msExitFullscreen;
                if (exitFS) exitFS.call(document);
                if (screen.orientation && screen.orientation.unlock) {
                    screen.orientation.unlock();
                }
            }
            if (isPseudoFS) exitPseudoFS();
        }
    }

    async function enterPseudoFS() {
        document.getElementById('player-wrapper').classList.add('pseudo-fullscreen');
        isPseudoFS = true;
        // Pseudo-fullscreen doesn't always allow API locking, but we try anyway
        if (screen.orientation && screen.orientation.lock) {
            await screen.orientation.lock('landscape').catch(() => {});
        }
        syncFullScreenUI();
    }

    function exitPseudoFS() {
        document.getElementById('player-wrapper').classList.remove('pseudo-fullscreen');
        isPseudoFS = false;
        if (screen.orientation && screen.orientation.unlock) {
            screen.orientation.unlock();
        }
        syncFullScreenUI();
    }

    function formatTime(seconds) {
        const h = Math.floor(seconds / 3600);
        const m = Math.floor((seconds % 3600) / 60);
        const s = Math.floor(seconds % 60);
        return `${h > 0 ? h + ':' : ''}${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
    }

    // 💬 Chat Polling Logic
    async function fetchMessages() {
        try {
            const res = await fetch(`/api/chat/${channelId}`);
            const messages = await res.json();
            const container = document.getElementById('chat-messages');
            container.innerHTML = messages.map(msg => `
                <div class="bg-white/5 p-3 rounded-2xl border border-white/5 animate-fade-in">
                    <span class="text-blue-500 font-bold text-[10px] uppercase">${msg.username}</span>
                    <p class="text-white/80 mt-1">${msg.text}</p>
                </div>
            `).join('');
            container.scrollTop = container.scrollHeight;
        } catch (e) { console.error("Chat sync failed", e); }
    }

    async function sendMessage() {
        const input = document.getElementById('chat-input');
        const text = input.value.trim();
        if (!text) return;

        await fetch(`/api/chat/${channelId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                username: tg.initDataUnsafe?.user?.first_name || "Guest", 
                text 
            })
        });
        input.value = '';
        fetchMessages();
    }

    // Init
    switchServer(0);
    setInterval(fetchMessages, 2000);
    fetchMessages();
  </script>
</body>
</html>