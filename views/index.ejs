<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TV Player</title>
  <style>
    body { margin: 0; font-family: Arial, sans-serif; background: #000; color: #fff; }
    header { padding: 16px; background: #111; }
    nav a { margin-right: 12px; color: #4fc3f7; text-decoration: none; }
    nav a.active { font-weight: bold; }
    .player { width: 100%; height: calc(100vh - 72px); }
    iframe { width: 100%; height: 100%; border: none; }
  </style>
</head>
<body>
  <header>
    <h1>TV Player</h1>
    <nav>
      <% for (const id in channels) { %>
        <a href="/?channel=<%= id %>" class="<%= id === selected ? 'active' : '' %>"><%= id %></a>
      <% } %>
    </nav>
  </header>
  <div class="player">
    <iframe src="<%= url %>" allowfullscreen sandbox="allow-same-origin allow-scripts allow-forms"></iframe>
  </div>
</body>
</html>
