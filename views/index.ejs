<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Premium Sports Stream</title>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0d0e12;
      --card-bg: #161820;
      --accent: #ff0033;
      --text: #ffffff;
      --text-dim: #94a3b8;
    }

    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .player-container {
      width: 100%;
      background: #000;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }

    #video {
      width: 100%;
      aspect-ratio: 16 / 9;
      display: block;
    }

    .match-selection {
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .match-card {
      text-decoration: none;
      color: inherit;
      background: var(--card-bg);
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      aspect-ratio: 16 / 8;
      border: 1px solid rgba(255, 255, 255, 0.05);
      transition: transform 0.2s, border-color 0.2s;
    }

    .match-card:active { transform: scale(0.98); }
    .match-card.active { border-color: var(--accent); box-shadow: 0 0 15px rgba(255, 0, 51, 0.2); }

    .card-top { padding: 12px; display: flex; justify-content: flex-start; }
    .live-badge {
      color: var(--accent);
      font-size: 0.7rem;
      font-weight: 800;
      background: rgba(255, 0, 51, 0.1);
      padding: 4px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .card-middle { flex: 1; display: flex; align-items: center; justify-content: center; gap: 24px; }
    .team-logo { width: 60px; height: 40px; object-fit: contain; }
    .vs-divider { font-weight: 800; font-size: 1.2rem; font-style: italic; opacity: 0.5; }
    .card-bottom { padding: 12px 16px; background: rgba(0,0,0,0.2); }
    .match-title { font-weight: 600; font-size: 1rem; margin-bottom: 2px; }
    .match-schedule { color: var(--text-dim); font-size: 0.75rem; font-weight: 400; }
  </style>
</head>
<body>
  <div class="player-container">
    <video id="video" controls playsinline></video>
  </div>

  <div class="match-selection">
    <% for (const id in channels) { %>
      <% const item = channels[id]; %>
      <a href="/?channel=<%= id %>" class="match-card <%= id === selectedId ? 'active' : '' %>">
        <div class="card-top"><div class="live-badge">● LIVE</div></div>
        <div class="card-middle">
          <img src="<%= item.logoLeft %>" class="team-logo" alt="Team 1">
          <div class="vs-divider">VS</div>
          <img src="<%= item.logoRight %>" class="team-logo" alt="Team 2">
        </div>
        <div class="card-bottom">
          <div class="match-title"><%= item.title %></div>
          <div class="match-schedule"><%= item.schedule %></div>
        </div>
      </a>
    <% } %>
  </div>

  <script>
    const video = document.getElementById('video');
    const streamUrl = '<%= match.streamUrl %>';
    if (Hls.isSupported()) {
      const hls = new Hls();
      hls.loadSource(streamUrl);
      hls.attachMedia(video);
      hls.on(Hls.Events.MANIFEST_PARSED, () => video.play().catch(() => {}));
    } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
      video.src = streamUrl;
      video.addEventListener('loadedmetadata', () => video.play().catch(() => {}));
    }
  </script>
</body>
</html>
