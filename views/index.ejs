<!DOCTYPE html>
<html lang="en">
<head>
  <script src='//libtl.com/sdk.js' data-zone='11094774' data-sdk='show_11094774'></script>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <title>90 ደቂቃ x 433 ስፖርት</title>
  <!-- External Dependencies -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Inter', sans-serif;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }
    .obsidian-bg { background-color: #0b0c10; }
    .glass-card { background: rgba(22, 24, 32, 0.8); backdrop-filter: blur(10px); }
    
    /* Custom scrollbar for channel list */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    .active-glow {
      box-shadow: 0 0 15px rgba(59, 130, 246, 0.5);
      border-color: #3b82f6;
    }
  </style>
</head>
<body class="obsidian-bg text-white min-h-screen flex flex-col items-center">
  
  <!-- 🍔 Obsidian Sidebar Drawer -->
  <div id="sidebar" class="fixed inset-y-0 left-0 w-64 glass-card border-r border-white/10 z-[200] transform -translate-x-full transition-transform duration-300 ease-in-out">
    <div class="p-6 flex flex-col h-full">
      <div class="flex justify-between items-center mb-10">
        <span class="text-xs font-black tracking-widest text-blue-500 uppercase">Navigation</span>
        <button onclick="toggleSidebar()" class="text-gray-400">✕</button>
      </div>
      <nav class="flex flex-col gap-6">
        <a href="/" class="text-sm font-bold border-b border-white/5 pb-2">Home Dashboard</a>
        <a href="https://t.me/+I4XcTqHq-zBlZjZk" target="_blank" class="text-sm text-gray-400 hover:text-white transition-colors">Follow our Telegram</a>
        <a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Follow our Facebook</a>
        <a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Follow our TikTok</a>
        <a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Follow our Instagram</a>
      </nav>
      <div class="mt-auto">
        <p class="text-[9px] text-gray-600 font-bold uppercase tracking-widest">90 ደቂቃ x 433 ስፖርት v1.0</p>
      </div>
    </div>
  </div>
  <!-- Overlay -->
  <div id="overlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/60 z-[150] hidden backdrop-blur-sm"></div>

  <!-- 🎨 Header Bar -->
  <header class="w-full max-w-md px-5 py-6 flex justify-between items-center">
    <button onclick="toggleSidebar()" class="p-2 -ml-2">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
    <h1 class="text-lg font-extrabold tracking-tighter text-blue-500">90 ደቂቃ x 433 ስፖርት</h1>
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 bg-red-600 rounded-full animate-pulse"></span>
    </div>
  </header>

  <main class="w-full max-w-5xl px-4">
    <div class="mb-8 max-w-md mx-auto md:mx-0">
      <h2 class="text-2xl font-black">እንኳን በደህና መጡ</h2>
      <p class="text-xs text-gray-500 font-medium">የፈለጉትን ጨዋታ መርጠው በቀጥታ ይመልከቱ</p>
    </div>

    <section class="pb-10">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-[11px] font-bold text-gray-500 uppercase tracking-[0.2em]">Live Matches</h3>
        <span class="text-[10px] text-blue-500/50 font-bold"><%= channels.length %> matches</span>
      </div>
      <div id="channel-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        <% channels.forEach((ch, index) => { %>
          <a href="/channel/<%= ch.id %>" class="glass-card group p-5 rounded-2xl border border-white/5 transition-all duration-300 hover:border-blue-500/50 hover:bg-white/[0.03] hover:shadow-[0_0_30px_rgba(59,130,246,0.1)] active:scale-[0.97] flex flex-col items-center">
            <!-- 🎏 Multi-Country Team & Flag Component -->
            <div class="flex items-center justify-around w-full mb-5 px-1">
              <div class="w-12 h-12 md:w-14 md:h-14 rounded-full bg-black/50 border border-white/10 flex items-center justify-center overflow-hidden shadow-inner transform transition-transform group-hover:scale-110">
                <img src="<%= ch.logoLeft || 'https://placehold.co/100x100/000/3b82f6?text=T1' %>" class="w-full h-full object-cover" alt="Team 1">
              </div>
              <div class="flex flex-col items-center">
                <span class="text-[10px] font-black italic text-blue-500/50">VS</span>
              </div>
              <div class="w-12 h-12 md:w-14 md:h-14 rounded-full bg-black/50 border border-white/10 flex items-center justify-center overflow-hidden shadow-inner transform transition-transform group-hover:scale-110">
                <img src="<%= ch.logoRight || 'https://placehold.co/100x100/000/3b82f6?text=T2' %>" class="w-full h-full object-cover" alt="Team 2">
              </div>
            </div>
            <!-- 📊 Match Info -->
            <div class="text-center w-full">
              <h4 class="text-[12px] font-extrabold tracking-tight text-white mb-2 line-clamp-1"><%= ch.title %></h4>
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-500/10 border border-red-500/20">
                <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span>
                <span class="text-[8px] font-black text-red-500 uppercase tracking-widest">Live Now</span>
              </div>
            </div>
          </a>

          <% /* Mid-Grid Responsive Banner: Injected after the first row (index 1 for mobile) */ %>
          <% if (promoConfig.showPromo && index === 1) { %>
            <a href="<%= promoConfig.link %>" target="_blank" class="col-span-full glass-card p-1 rounded-2xl border border-blue-500/30 overflow-hidden relative group transition-all duration-500 hover:shadow-[0_0_40px_rgba(59,130,246,0.2)] active:scale-[0.98]">
              <div class="absolute inset-0 bg-gradient-to-r from-blue-600/10 to-transparent pointer-events-none"></div>
              <div class="flex items-center gap-4 p-4 relative z-10">
                <div class="w-14 h-14 md:w-16 md:h-16 shrink-0 rounded-xl overflow-hidden border border-white/10 shadow-2xl transform transition-transform group-hover:scale-105">
                  <img src="<%= promoConfig.imageUrl %>" class="w-full h-full object-cover" alt="Promo">
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-[9px] font-black text-blue-500 uppercase tracking-[0.2em] px-2 py-0.5 rounded bg-blue-500/10 border border-blue-500/20">Sponsored</span>
                  </div>
                  <p class="text-sm md:text-base font-black tracking-tight text-white group-hover:text-blue-400 transition-colors line-clamp-2"><%= promoConfig.text %></p>
                </div>
                <div class="hidden sm:flex px-5 py-2.5 bg-blue-600 hover:bg-blue-500 rounded-xl text-xs font-black uppercase tracking-widest shadow-lg shadow-blue-500/20 transition-all">Join</div>
              </div>
            </a>
          <% } %>
        <% }) %>
      </div>
    </section>
  </main>

  <footer class="fixed bottom-0 left-0 right-0 py-3 glass-card border-t border-white/5 px-6 flex justify-between items-center z-[100]">
    <div class="text-[10px] text-gray-400 font-medium tracking-wide">Enjoy</div>
    <div class="text-[10px] text-blue-500 font-bold tracking-widest uppercase"> 90 ደቂቃ x 433 ስፖርት </div>
  </footer>

  <script>
    const telegram = window.Telegram.WebApp;
    telegram.ready();
    telegram.expand();

    // 💰 Monetag In-App Interstitial Initialization
    if (typeof show_11094774 === 'function') {
      show_11094774({
        type: 'inApp',
        inAppSettings: {
          frequency: 2,
          capping: 0.1,
          interval: 30,
          timeout: 5,
          everyPage: false // Ensures session persists cleanly across channel transitions
        }
      });
    }

    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('overlay');
      const isHidden = sidebar.classList.contains('-translate-x-full');
      
      sidebar.classList.toggle('-translate-x-full', !isHidden);
      overlay.classList.toggle('hidden', !isHidden);
    }
  </script>
</body>
</html>
